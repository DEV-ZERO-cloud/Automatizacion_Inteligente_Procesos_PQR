# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales
.venv/
venv/
env/
ENV/

# Variables de entorno
.env
.env.*

# Archivos de logs
*.log

# Archivos de base de datos locales
*.sqlite3
*.db

# Archivos de configuración del sistema
.DS_Store
Thumbs.db

# Archivos de testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Archivos de Jupyter
.ipynb_checkpoints/

# Archivos de compilación / distribución
build/
dist/
*.egg-info/
.eggs/

# Archivos de editores / IDE
.vscode/
.idea/

# Archivos temporales
*.tmp
*.bak

# Alembic (opcional si generas migraciones y no quieres versiones temporales)
